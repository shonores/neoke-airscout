# ──────────────────────────────────────────────────────────────────────────────
# AirScout verifier credentials (Vercel → Settings → Environment Variables)
# ──────────────────────────────────────────────────────────────────────────────

# AirScout's own IDN node identifier (e.g. "b2b-poc")
VITE_AIRSCOUT_NODE_ID=

# AirScout's API key for that node
VITE_AIRSCOUT_API_KEY=

# Consent Engine URL (leave blank to use the shared Neoke CE)
VITE_AIRSCOUT_CE_URL=https://neoke-consent-engine.fly.dev

# ──────────────────────────────────────────────────────────────────────────────
# Discovery service (server-side Vercel function — no VITE_ prefix needed)
# ──────────────────────────────────────────────────────────────────────────────

# JSON map of email → DID for the demo user registry
# Example: {"alice@example.com":"did:web:alice.id-node.neoke.com"}
DEMO_DID_MAP={}

# ──────────────────────────────────────────────────────────────────────────────
# Upstash Redis (server-side — stores VP callback results keyed by sessionId)
# Connect via: Vercel dashboard → Storage → Upstash → Connect to project
# ──────────────────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

